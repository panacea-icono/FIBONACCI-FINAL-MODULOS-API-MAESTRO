# Variables de entorno de ejemplo

# Token de Hugging Face
HF_TOKEN=

# Modelo por defecto para examples/connect_huggingface.py
HF_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# Puertos sugeridos para servicios (ajusta según necesidades)
APP_PORT=8000
LAB_PORT=8001
GPTS_MEDICOS_PORT=8002
PANAS_TOKEN_PORT=8010
VASER_TOKEN_PORT=8011

# OpenAI (para integraciones opcionales)
OPENAI_API_KEY=

# Modelos opcionales de visión/dermatología
# Ejemplo skin: "microsoft/resnet-50" o un modelo HAM10000 de HF Hub
HF_SKIN_MODEL_ID=
# Ejemplo caption: "Salesforce/blip-image-captioning-base"
HF_IMAGE_CAPTION_MODEL=
